{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "Microsoft.EntityFrameworkCore.Database.Command": "Information"
        }
    },
    "Kestrel": {
        "Endpoints": {
            "RestHttp": {
                "Url": "http://localhost:5173",
                "Protocols": "Http1"
            },
            "Grpc": {
                "Url": "http://localhost:5222",
                "Protocols": "Http2"
            }
        }
    },
    "Serilog": {
        "Using": [
            "Serilog.Sinks.Console"
        ],
        "MinimumLevel": {
            "Default": "Debug",
            "Override": {
                "Default": "Information",
                "Microsoft": "Warning",
                "Microsoft.Hosting.Lifetime": "Information"
            }
        },
        "Enrich": [
            "FromLogContext",
            "WithMachineName",
            "WithThreadId"
        ],
        "Destructure": [
            {
                "Name": "ToMaximumDepth",
                "Args": {
                    "maximumDestructuringDepth": 4
                }
            },
            {
                "Name": "ToMaximumStringLength",
                "Args": {
                    "maximumStringLength": 100
                }
            },
            {
                "Name": "ToMaximumCollectionCount",
                "Args": {
                    "maximumCollectionCount": 10
                }
            }
        ],
        "Properties": {
            "Application": "Todo.Api"
        }
    },
    "Observability": {
        "ServiceName": "Todo.WebApi",
        "ServiceVersion": "1.0.0-dev",
        "DeploymentEnvironment": "Development"
    },
    "OpenTelemetry": {
        "Endpoint": "http://localhost:4317",
        "Protocol": "grpc",
        "Headers": "",
        "TraceSampler": "parentbased_traceidratio",
        "TraceSamplerArg": 1.0
    },
    "AllowedHosts": "*",
    "ConnectionStrings": {
        "postgres": "Host=localhost; Database=axes; Username=postgres; Password=5161"
    },
    "Redis": {
        "ConnectionString": "localhost:6379"
    },
    "Jwt": {
        "Key": "548D2CD2E32A729C16BE57471F5B2C7305DADC6D04294482175A66DDEA62383D",
        "Issuer": "AxesServiceServer",
        "Audience": "AxesClient",
        "Subject": "AxesServiceToken"
    }
}
